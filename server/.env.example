# Veyano Foods — Backend Environment Variables
# Copy this file to .env and fill in your real values

# ── Server ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Security ───────────────────────────────────────
JWT_SECRET=veyano_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# ── Razorpay ───────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret
RAZORPAY_WEBHOOK_SECRET=placeholder_webhook_secret

# ── Database ───────────────────────────────────────
DB_PATH=./veyano.db

# ── Shiprocket ─────────────────────────────────────
SHIPROCKET_EMAIL=your_shiprocket_email@example.com
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_API_URL=https://apiv2.shiprocket.in/v1/external

# ── Email (Gmail SMTP) ─────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=veyanofoods@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── AWS S3 Backups ──────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=veyano-db-backups

# ── Admin ───────────────────────────────────────────
ADMIN_EMAIL=admin@veyanofoods.com
FRONTEND_URL=http://localhost:5500
